{
  "name": "nova-docs",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "node ../../scripts/run-scripts.mjs --parallel 'dev:*'",
    "dev:start": "docusaurus start --port 3100",
    "prod": "node ../../scripts/run-scripts.mjs --sequential 'prod:*'",
    "prod:serve": "docusaurus serve ./",
    "build": "node ../../scripts/run-scripts.mjs --sequential 'build:*'",
    "build:build": "docusaurus build",
    "build:transpile": "tsc --project tsconfig.json --outDir ./build --skipLibCheck",
    "build:fix-aliases": "node ../../scripts/fix-aliases.mjs",
    "check": "node ../../scripts/run-scripts.mjs --parallel 'check:*'",
    "check:lint": "eslint ./ --max-warnings=0",
    "check:types": "tsc --noEmit --skipLibCheck",
    "check:test": "node --test ./build/src/tests/**/*.test.js",
    "clean": "node ../../scripts/run-scripts.mjs --parallel 'clean:*'",
    "clean:build": "shx rm -rf ./build",
    "clean:clear": "docusaurus clear"
  },
  "engines": {
    "node": "^20 || ^22 || ^24"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@easyops-cn/docusaurus-search-local": "0.54.1",
    "@iconify/react": "6.0.2",
    "@mdx-js/react": "3.1.1",
    "prism-react-renderer": "2.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cbnventures/nova": "file:../../packages/nova",
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "@types/node": "24.9.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "docusaurus-plugin-module-alias": "0.0.2",
    "eslint": "9.39.3",
    "shx": "0.4.0",
    "typescript": "5.9.3"
  }
}
