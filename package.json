{
  "name": "nova-project",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter='./packages/*' --filter=nova-docs",
    "prod": "turbo run prod --filter='./packages/*' --filter=nova-docs",
    "build": "turbo run build --filter='./packages/*' --filter=nova-docs",
    "check": "turbo run check --filter='./packages/*' --filter=nova-docs",
    "deploy": "turbo run deploy --filter='./packages/*' --filter=nova-docs",
    "clean": "turbo run clean --filter='./packages/*' --filter=nova-docs",
    "changelog": "nova utility changelog",
    "recipes": "nova utility run-recipes --replace-file",
    "demos": "node ./scripts/run-demos.mjs",
    "postinstall": "node ./scripts/link-nova.mjs"
  },
  "workspaces": [
    "./apps/*",
    "./packages/*"
  ],
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "^20 || ^22 || ^24"
  },
  "devDependencies": {
    "@cbnventures/nova": "file:./packages/nova",
    "@inquirer/prompts": "8.4.3",
    "chalk": "5.6.2",
    "chokidar": "3.6.0",
    "jiti": "2.6.1",
    "turbo": "2.9.5",
    "typescript": "5.9.3"
  },
  "overrides": {
    "webpack": ">=5.95.0 <5.106.0"
  }
}
