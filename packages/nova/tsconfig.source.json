{
  "extends": [
    "./src/presets/tsconfig/dx-essentials.json",
    "./src/presets/tsconfig/dx-strict.json",
    "./src/presets/tsconfig/runtime-node.json"
  ],
  "compilerOptions": {
    "outDir": "./build",
    "rootDir": "./",
    "types": [
      "@commander-js/extra-typings",
      "@types/eslint-plugin-jsx-a11y",
      "@types/node",
      "@types/prompts"
    ]
  },
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "./build/**",
    "./node_modules/**",
    "./src/tests/**"
  ]
}
