{
  "project": {
    "name": {
      "title": "Nova",
      "slug": "nova"
    },
    "description": {
      "short": "Scripts, templates, and project configuration for the common JavaScript and TypeScript developer",
      "long": "Nova is a JavaScript and TypeScript monorepo suite, offering strict presets and guided tooling to help you build with confidence, predictability, and minimal setup. It delivers strong defaults, robust linting and typing, and scaffolded project generators — all wrapped in guardrails that keep your workflow safe without sacrificing flexibility."
    },
    "keywords": [
      "eslint",
      "eslint-config",
      "eslint-flat-config",
      "typescript",
      "tsconfig",
      "tsconfig-presets",
      "linting",
      "code-style",
      "scripts",
      "templates",
      "docusaurus-preset",
      "react",
      "nextjs",
      "node",
      "monorepo"
    ],
    "legalName": "CBN Ventures LLC",
    "pronouns": "business",
    "platforms": [
      "nodejs"
    ],
    "startingYear": 2025,
    "license": "MIT"
  },
  "entities": [
    {
      "name": "CBN Ventures",
      "email": "contact@cbnventures.io",
      "url": "https://www.cbnventures.io/",
      "roles": [
        "author"
      ]
    },
    {
      "name": "Jacky Liang",
      "email": "hello@mrjackyliang.com",
      "url": "https://www.mrjackyliang.com/",
      "roles": [
        "contributor",
        "supporter"
      ]
    }
  ],
  "emails": {
    "bugs": "bugs@cbnventures.io"
  },
  "workflows": [
    {
      "template": "check-sponsor-gated-issues",
      "suffix": "project",
      "triggers": [
        "issue-comment",
        "issues"
      ],
      "settings": {
        "IS_ORGANIZATION": "IS_ORGANIZATION",
        "ISSUE_LABELS": "ISSUE_LABELS",
        "ISSUE_LIMIT_COMMENTER": "ISSUE_LIMIT_COMMENTER",
        "ISSUE_LOCK_ON_CLOSE": "ISSUE_LOCK_ON_CLOSE",
        "ISSUE_MESSAGE_NOT_SPONSOR": "ISSUE_MESSAGE_NOT_SPONSOR",
        "ISSUE_MESSAGE_WELCOME": "ISSUE_MESSAGE_WELCOME",
        "PERSONAL_ACCESS_TOKEN": "PERSONAL_ACCESS_TOKEN",
        "SPONSOR_ACTIVE_ONLY": "SPONSOR_ACTIVE_ONLY",
        "SPONSOR_EXEMPT_FILE_LOCATION": "SPONSOR_EXEMPT_FILE_LOCATION",
        "SPONSOR_MINIMUM": "SPONSOR_MINIMUM"
      }
    },
    {
      "template": "lock-inactive-issues",
      "suffix": "project",
      "triggers": [
        "schedule-weekly"
      ]
    },
    {
      "template": "publish",
      "suffix": "project",
      "triggers": [
        "release"
      ],
      "scopes": [
        "./packages/nova",
        "./packages/docusaurus-preset-nova",
        "./apps/docs"
      ],
      "targets": [
        {
          "type": "npm",
          "workingDir": "./packages/nova"
        },
        {
          "type": "npm",
          "workingDir": "./packages/docusaurus-preset-nova",
          "needs": [
            "./packages/nova"
          ]
        },
        {
          "type": "github-packages",
          "workingDir": "./packages/nova"
        },
        {
          "type": "github-packages",
          "workingDir": "./packages/docusaurus-preset-nova",
          "needs": [
            "./packages/nova"
          ]
        },
        {
          "type": "cloudflare-pages-docusaurus",
          "workingDir": "./apps/docs"
        }
      ],
      "settings": {
        "CLOUDFLARE_ACCOUNT_ID": "CLOUDFLARE_ACCOUNT_ID",
        "CLOUDFLARE_API_TOKEN": "CLOUDFLARE_API_TOKEN",
        "CLOUDFLARE_PROJECT_NAME": "CLOUDFLARE_PROJECT_NAME",
        "NPM_TOKEN": "NPM_TOKEN",
        "ROOT_WORKING_DIR": "./"
      }
    }
  ],
  "urls": {
    "homepage": "https://nova.cbnventures.io/",
    "repository": "git+https://github.com/cbnventures/nova.git",
    "bugs": "https://github.com/cbnventures/nova/issues",
    "license": "https://github.com/cbnventures/nova/blob/HEAD/LICENSE",
    "logo": "https://nova.cbnventures.io/images/logo.svg",
    "documentation": "https://nova.cbnventures.io/",
    "github": "https://github.com/cbnventures/nova",
    "npm": "https://www.npmjs.com/package/@cbnventures/nova",
    "fundSources": [
      "https://github.com/sponsors/cbnventures",
      "https://www.paypal.com/biz/profile/cbnventures"
    ],
    "privacyPolicy": "https://www.cbnventures.io/privacy/",
    "termsOfUse": "https://www.cbnventures.io/terms/"
  },
