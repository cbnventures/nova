{
  "name": "@cbnventures/nova",
  "version": "0.16.2",
  "description": "Scripts, templates, and project configuration for the common JavaScript and TypeScript developer",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-flat-config",
    "typescript",
    "tsconfig",
    "tsconfig-presets",
    "linting",
    "code-style",
    "scripts",
    "templates",
    "docusaurus-preset",
    "react",
    "nextjs",
    "node",
    "monorepo"
  ],
  "license": "MIT",
  "homepage": "https://nova.cbnventures.io/",
  "bugs": {
    "email": "bugs@cbnventures.io",
    "url": "https://github.com/cbnventures/nova/issues"
  },
  "author": {
    "name": "CBN Ventures",
    "email": "contact@cbnventures.io",
    "url": "https://www.cbnventures.io/"
  },
  "contributors": [
    {
      "name": "Jacky Liang",
      "email": "hello@mrjackyliang.com",
      "url": "https://www.mrjackyliang.com/"
    }
  ],
  "funding": [
    "https://github.com/sponsors/cbnventures",
    "https://www.paypal.com/biz/profile/cbnventures"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbnventures/nova.git",
    "directory": "packages/nova"
  },
  "exports": {
    "./rules/eslint": "./build/src/rules/eslint/index.js",
    "./rules/eslint/*": "./build/src/rules/eslint/*.js",
    "./presets/eslint": "./build/src/presets/eslint/index.js",
    "./presets/eslint/*": "./build/src/presets/eslint/*.js",
    "./presets/tsconfig/dx-essentials.json": "./build/src/presets/tsconfig/dx-essentials.json",
    "./presets/tsconfig/dx-strict.json": "./build/src/presets/tsconfig/dx-strict.json",
    "./presets/tsconfig/fw-docusaurus.json": "./build/src/presets/tsconfig/fw-docusaurus.json",
    "./presets/tsconfig/fw-expressjs.json": "./build/src/presets/tsconfig/fw-expressjs.json",
    "./presets/tsconfig/fw-nextjs.json": "./build/src/presets/tsconfig/fw-nextjs.json",
    "./presets/tsconfig/runtime-browser.json": "./build/src/presets/tsconfig/runtime-browser.json",
    "./presets/tsconfig/runtime-cloudflare-workers.json": "./build/src/presets/tsconfig/runtime-cloudflare-workers.json",
    "./presets/tsconfig/runtime-edge.json": "./build/src/presets/tsconfig/runtime-edge.json",
    "./presets/tsconfig/runtime-node.json": "./build/src/presets/tsconfig/runtime-node.json",
    "./presets/tsconfig/runtime-service-worker.json": "./build/src/presets/tsconfig/runtime-service-worker.json",
    "./presets/tsconfig/runtime-web-worker.json": "./build/src/presets/tsconfig/runtime-web-worker.json",
    "./presets/tsconfig/tool-vite.json": "./build/src/presets/tsconfig/tool-vite.json",
    "./toolkit": "./build/src/toolkit/index.js",
    "./toolkit/*": "./build/src/toolkit/*.js",
    "./types/*": "./build/src/types/*"
  },
  "type": "module",
  "files": [
    "./bin",
    "./build"
  ],
  "bin": {
    "nova": "bin/nova.mjs"
  },
  "private": false,
  "scripts": {
    "dev": "node ../../scripts/run-scripts.mjs --parallel 'dev:*'",
    "dev:watch": "tsc --project tsconfig.source.json --watch",
    "build": "node ../../scripts/run-scripts.mjs --sequential 'build:*'",
    "build:transpile-source": "tsc --project tsconfig.source.json --outDir ./build --skipLibCheck",
    "build:copy-types": "shx rm -rf \"./build/src/types\" && shx cp -r \"./src/types\" \"./build/src/types\"",
    "build:copy-tsconfig-presets": "shx rm -rf \"./build/src/presets/tsconfig\" && shx cp -r \"./src/presets/tsconfig\" \"./build/src/presets/tsconfig\"",
    "build:fix-perms": "shx chmod +x ./build/src/cli/index.js",
    "build:copy-templates": "shx rm -rf \"./build/templates\" && shx cp -r \"./templates\" \"./build/templates\"",
    "check": "node ../../scripts/run-scripts.mjs --sequential 'check:*'",
    "check:lint": "eslint ./ --max-warnings=0",
    "check:types-source": "node ../../scripts/type-check.mjs --project tsconfig.source.json",
    "check:types-tests": "node ../../scripts/type-check.mjs --project tsconfig.tests.json",
    "check:test": "vitest run",
    "clean": "node ../../scripts/run-scripts.mjs --parallel 'clean:*'",
    "clean:build": "shx rm -rf ./build"
  },
  "engines": {
    "node": "^20 || ^22 || ^24"
  },
  "dependencies": {
    "@eslint/js": "9.39.3",
    "@stylistic/eslint-plugin": "5.10.0",
    "@typescript-eslint/parser": "8.58.1",
    "@typescript-eslint/utils": "8.58.1",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "eslint-mdx": "3.7.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-mdx": "3.7.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "17.4.0",
    "prompts": "2.4.2",
    "typescript-eslint": "8.58.1",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "14.0.0",
    "@types/eslint-plugin-jsx-a11y": "6.10.1",
    "@types/node": "24.9.1",
    "@types/prompts": "2.4.9",
    "@typescript-eslint/rule-tester": "8.58.1",
    "eslint": "9.39.3",
    "eslint-import-resolver-typescript": "4.4.4",
    "glob": "13.0.6",
    "shx": "0.4.0",
    "typescript": "5.9.3",
    "vitest": "4.1.3"
  },
  "peerDependencies": {
    "eslint": "^9",
    "typescript": "^5"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  }
}
