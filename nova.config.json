  "workspaces": {
    "./": {
      "name": "nova-project",
      "role": "project",
      "policy": "freezable",
      "recipes": {
        "cleanup": [
          true,
          {
            "removeUnknownKeys": true,
            "reorderKeys": true
          }
        ],
        "normalize-artifacts": [
          true
        ],
        "normalize-bundler": [
          true
        ],
        "normalize-dependencies": [
          true,
          {
            "pinDependencyVersions": true,
            "pinDevDependencyVersions": true
          }
        ],
        "normalize-modules": [
          true
        ],
        "normalize-tooling": [
          true
        ],
        "sync-environment": [
          true,
