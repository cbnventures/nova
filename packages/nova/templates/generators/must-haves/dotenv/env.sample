# NODE_ENV: development | production | test
NODE_ENV="development"

#########################
#### Nova - CLI Logs ####
#########################
# LOG_LEVEL: debug | info | warn | error | auto (auto derives the level from NODE_ENV)
LOG_LEVEL="auto"
# LOG_TIME: true | false
LOG_TIME="false"

